%% =====================================================================
%% FIGURA FINAL: Todas las fuentes superpuestas en un solo panel por día
%%               con todos los días de monitoreo en una sola figura
%% =====================================================================

% Layout: 3 filas × 4 columnas = 12 paneles (uno por mes)
n_cols = 4;
n_rows = ceil(n_samples / n_cols);   % = 3 for 12 months

fig_combined = figure('Position', [50, 50, 1600, 900], ...
                      'Name', 'Distribuciones combinadas – todos los días');

% Shared legend handles (built once, used below)
legend_handles = gobjects(3, 1);

for d = 1:n_samples
    ax = subplot(n_rows, n_cols, d);
    hold(ax, 'on');
    
    max_pdf = 0;   % track for y-limit
    
    for k = 1:3
        data = src_data{k}{d};
        if isempty(data)
            continue;
        end
        
        % --- KDE-smoothed curve overlaid on transparent histogram ---
        % Histogram (transparent fill for context)
        hh = histogram(ax, data, 35, ...
                       'Normalization', 'pdf', ...
                       'FaceColor', src_colors{k}, ...
                       'EdgeColor', 'none', ...
                       'FaceAlpha', 0.22);
        
        % Smooth KDE line
        % Clamp data slightly away from hard boundaries to avoid ksdensity
        % errors when values sit exactly at 0 or 100.
        data_kde = min(max(data, 0.01), 99.99);
        [f_kde, xi_kde] = ksdensity(data_kde);
        % Restrict evaluation range to [0, 100] for display consistency
        in_range = xi_kde >= 0 & xi_kde <= 100;
        xi_kde = xi_kde(in_range);
        f_kde  = f_kde(in_range);
        ph = plot(ax, xi_kde, f_kde, '-', ...
                  'Color', src_colors{k}, ...
                  'LineWidth', 2.2);
        
        % Vertical dashed line at mean
        mn_d = mean(data);
        xline(ax, mn_d, '--', 'Color', src_colors{k}, 'LineWidth', 1.4, 'Alpha', 0.8);
        
        % Track max for y-scaling
        max_pdf = max(max_pdf, max(f_kde));
        
        % Store handle for legend (only first day, reuse same colours)
        if d == 1
            legend_handles(k) = ph;
        end
    end
    
    % Formatting
    title(ax, day_labels{d}, 'FontSize', 11, 'FontWeight', 'bold');
    xlabel(ax, 'Contribución (%)', 'FontSize', 8.5);
    if mod(d-1, n_cols) == 0          % left-most panels only
        ylabel(ax, 'Densidad PDF', 'FontSize', 8.5);
    end
    xlim(ax, [0 100]);
    ylim(ax, [0, max_pdf * 1.18]);
    grid(ax, 'on');
    box(ax, 'on');
    set(ax, 'FontSize', 8);
    hold(ax, 'off');
end

