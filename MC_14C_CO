%% Simulaciones Monte Carlo modalidad 14C + CO/CO2 (MATLAB)
%% Monte Carlo Parameters
n_simulations = 50000;
rng(42);

%% SOURCE CHARACTERISTICS
fossil_C14        = -1000;
fossil_C14_std    = 0;
fossil_CO_CO2     = 0.0139;
fossil_CO_CO2_std = 0.003;

biomass_C14        = 57;
biomass_C14_std    = 67;
biomass_CO_CO2     = 0.045;
biomass_CO_CO2_std = 0.004;

soil_C14        = 5;
soil_C14_std    = 15;
soil_CO_CO2     = 0;
soil_CO_CO2_std = 0;

%% INPUT DATA
obs_CO_CO2 = [0.016345081
0.01343201
0.01690236
0.015889727
0.016432268
0.011701939
