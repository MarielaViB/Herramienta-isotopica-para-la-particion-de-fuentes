%% Etiquetas de días de monitoreo
day_labels = {'Dic 23','Ene','Feb','Mar','Abr','May','Jun','Jun II','Jul','Ago',...
              'Ago II','Sep','Oct','Nov','Dic 24'};

n_samples = length(obs_CO_CO2);

%% Initialize results storage
results = struct();
results.sample_id = (1:n_samples)';

fields = {'fossil','biomass','soil'};
stats  = {'mean','std','median','p5','p95'};
for f = 1:numel(fields)
    for s = 1:numel(stats)
        results.([fields{f} '_' stats{s}]) = zeros(n_samples, 1);
    end
end
results.n_valid      = zeros(n_samples, 1);
results.success_rate = zeros(n_samples, 1);

%% Guardar distribuciones completas
all_fossil_dist  = cell(n_samples, 1);
all_biomass_dist = cell(n_samples, 1);
all_soil_dist    = cell(n_samples, 1);

%% Process each sampling day
fprintf('=== BATCH CO2 SOURCE APPORTIONMENT (14C + CO/CO2) ===\n');
fprintf('Processing %d sampling days with %d Monte Carlo iterations each\n\n', ...
        n_samples, n_simulations);

for sample_idx = 1:n_samples
    fprintf('--- Day %d/%d ---\n', sample_idx, n_samples);
    
    f_fossil  = zeros(n_simulations, 1);
    f_biomass = zeros(n_simulations, 1);
    f_soil    = zeros(n_simulations, 1);
    valid_solutions = false(n_simulations, 1);
    
    for i = 1:n_simulations
        CO_CO2_sample = normrnd(obs_CO_CO2(sample_idx), obs_CO_CO2_std(sample_idx));
        C14_sample    = normrnd(obs_C14(sample_idx),    obs_C14_std(sample_idx));
        
        fossil_C14_s  = normrnd(fossil_C14,    fossil_C14_std);
        fossil_CO_s   = normrnd(fossil_CO_CO2, fossil_CO_CO2_std);
        biomass_C14_s = normrnd(biomass_C14,   biomass_C14_std);
        biomass_CO_s  = normrnd(biomass_CO_CO2,biomass_CO_CO2_std);
        soil_C14_s    = normrnd(soil_C14,      soil_C14_std);
        
        fossil_CO_s   = max(0, fossil_CO_s);
        biomass_CO_s  = max(0, biomass_CO_s);
        CO_CO2_sample = max(0, CO_CO2_sample);
        
        A = [1, 1, 1;
             fossil_C14_s, biomass_C14_s, soil_C14_s;
             fossil_CO_s,  biomass_CO_s,  soil_CO_CO2];
        b = [1; C14_sample; CO_CO2_sample];
        
        try
            fractions = A \ b;
            if all(fractions >= -0.01) && all(fractions <= 1.01) && ...
               abs(sum(fractions) - 1) < 0.01
                f_fossil(i)  = max(0, min(1, fractions(1)));
                f_biomass(i) = max(0, min(1, fractions(2)));
                f_soil(i)    = max(0, min(1, fractions(3)));
                total = f_fossil(i) + f_biomass(i) + f_soil(i);
                if total > 0
                    f_fossil(i)  = f_fossil(i)  / total;
                    f_biomass(i) = f_biomass(i) / total;
                    f_soil(i)    = f_soil(i)    / total;
                    valid_solutions(i) = true;
                end
            end
        catch
            continue;
        end
    end
    
    f_fossil_valid  = f_fossil(valid_solutions)  * 100;
    f_biomass_valid = f_biomass(valid_solutions) * 100;
    f_soil_valid    = f_soil(valid_solutions)    * 100;
    n_valid = sum(valid_solutions);
    
    % Guardar distribuciones
    all_fossil_dist{sample_idx}  = f_fossil_valid;
    all_biomass_dist{sample_idx} = f_biomass_valid;
    all_soil_dist{sample_idx}    = f_soil_valid;
    
    results.n_valid(sample_idx)      = n_valid;
    results.success_rate(sample_idx) = 100 * n_valid / n_simulations;
    
    if n_valid > 100
        results.fossil_mean(sample_idx)   = mean(f_fossil_valid);
        results.fossil_std(sample_idx)    = std(f_fossil_valid);
        results.fossil_median(sample_idx) = median(f_fossil_valid);
        results.fossil_p5(sample_idx)     = prctile(f_fossil_valid, 5);
        results.fossil_p95(sample_idx)    = prctile(f_fossil_valid, 95);
        
        results.biomass_mean(sample_idx)   = mean(f_biomass_valid);
        results.biomass_std(sample_idx)    = std(f_biomass_valid);
        results.biomass_median(sample_idx) = median(f_biomass_valid);
        results.biomass_p5(sample_idx)     = prctile(f_biomass_valid, 5);
        results.biomass_p95(sample_idx)    = prctile(f_biomass_valid, 95);
        
        results.soil_mean(sample_idx)   = mean(f_soil_valid);
        results.soil_std(sample_idx)    = std(f_soil_valid);
        results.soil_median(sample_idx) = median(f_soil_valid);
        results.soil_p5(sample_idx)     = prctile(f_soil_valid, 5);
        results.soil_p95(sample_idx)    = prctile(f_soil_valid, 95);
        
        fprintf('Valid: %d (%.1f%%) | Fossil: %.1f±%.1f%% | Biomass: %.1f±%.1f%% | Soil: %.1f±%.1f%%\n\n', ...
                n_valid, results.success_rate(sample_idx), ...
                results.fossil_mean(sample_idx),  results.fossil_std(sample_idx), ...
                results.biomass_mean(sample_idx), results.biomass_std(sample_idx), ...
                results.soil_mean(sample_idx),    results.soil_std(sample_idx));
    else
        fprintf('WARNING: Insufficient valid solutions (%d)\n\n', n_valid);
    end
end

%% =====================================================================
%% FIGURA: Histogramas Monte Carlo por día de monitoreo
%% =====================================================================

src_data   = {all_fossil_dist,  all_biomass_dist,  all_soil_dist};
src_names  = {'Combustión fósil','Quema de biomasa','Respiración de suelos'};
src_colors = {[0.45 0.45 0.45], [0.75 0.25 0.25], [0.25 0.65 0.25]};

for d = 1:n_samples
    figure('Position', [100, 100, 1300, 380], ...
           'Name', sprintf('Distribuciones Monte Carlo - %s', day_labels{d}));
    
    for k = 1:3
        subplot(1, 3, k);
        data = src_data{k}{d};
        
        if isempty(data)
            text(0.5, 0.5, 'Sin datos', 'HorizontalAlignment', 'center');
            continue;
        end
        
        mn  = mean(data);
        md  = median(data);
        sd  = std(data);
        p5  = prctile(data, 5);
        p95 = prctile(data, 95);
        
        % Histograma
        histogram(data, 40, 'Normalization', 'pdf', ...
                  'FaceColor', src_colors{k}, 'EdgeColor', 'none', 'FaceAlpha', 0.85);
        hold on;
        
        % Líneas verticales
        xline(mn,  '--', 'Color', src_colors{k}*0.6, 'LineWidth', 2.0);
        xline(p5,  ':',  'Color', src_colors{k}*0.6, 'LineWidth', 1.5);
        xline(p95, ':',  'Color', src_colors{k}*0.6, 'LineWidth', 1.5);
        
        % Obtener límites Y para colocar etiquetas al tope
        ylims = ylim;
        ytop  = ylims(2) * 0.97;
        
        % Etiquetas al tope
        text(mn,  ytop, sprintf(' Media\n %.1f%%', mn), ...
             'FontSize', 7.5, 'Color', src_colors{k}*0.5, ...
             'VerticalAlignment', 'top', 'HorizontalAlignment', 'left');
        text(p5,  ytop, sprintf('IC 95%%\n %.1f%%', p5), ...
             'FontSize', 7.5, 'Color', src_colors{k}*0.5, ...
             'VerticalAlignment', 'top', 'HorizontalAlignment', 'right');
        text(p95, ytop, sprintf('IC 95%%\n %.1f%%', p95), ...
             'FontSize', 7.5, 'Color', src_colors{k}*0.5, ...
             'VerticalAlignment', 'top', 'HorizontalAlignment', 'left');
        
        % Título solo con nombre de fuente
        title(src_names{k}, 'FontSize', 11, 'FontWeight', 'bold');
        xlabel('Contribución (%)', 'FontSize', 10);
        ylabel('Densidad de probabilidad', 'FontSize', 10);
        xlim([0, 100]);
        grid on; box on;
        hold off;
    end
    
    sgtitle(sprintf('Monitoreo: %s', day_labels{d}), ...
            'FontSize', 13, 'FontWeight', 'bold');
end

