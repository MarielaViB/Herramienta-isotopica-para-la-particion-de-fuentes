// Create the legend
var makeRow = function(color, name) {
  var colorBox = ui.Label({
    style: {
      backgroundColor: color,
      padding: '8px',
      margin: '0 0 4px 0'
    }
  });
  
  var description = ui.Label({
    value: name,
    style: {margin: '0 0 4px 6px'}
  });
  
  return ui.Panel({
    widgets: [colorBox, description],
    layout: ui.Panel.Layout.Flow('horizontal')
  });
};

// Create legend items
var ranges = [
  '0-300', '300-600', '600-900', 
  '900-1200', '1200+'
];

for (var i = 0; i < 5; i++) {
  precipLegend.add(makeRow(precipPalette[i], ranges[i]));
}

// Add legend to map
Map.add(precipLegend);

