// Visualize the region
Map.centerObject(CDMX, 10);
Map.addLayer(CDMX, {color: '#009999'}, 'Mexico City Area');

// Import the CHIRPS precipitation dataset at pentad (5-day) resolution
var chirps = ee.ImageCollection("UCSB-CHG/CHIRPS/PENTAD")
  .filterDate('2024-01-01', '2024-12-31') // Full year of 2024
  .filterBounds(CDMX);

// Process each pentad image to properly assign dates and display
var processed_chirps = chirps.map(function(image) {
  // Get the date info
  var date = ee.Date(image.get('system:time_start'));
  var doy = date.getRelative('day', 'year').add(1); // Day of year
  
  // Calculate pentad number (1-73 for the year)
  var pentadNum = doy.divide(5).ceil().toInt();
  
  // Format date for display
  var dateString = date.format('YYYY-MM-dd');
  
  // Return image with useful properties
  return image.set({
    'pentad': pentadNum,
    'date_string': dateString,
    'month': date.get('month'),
    'date_millis': date.millis()
  });
});

// Create a visualization for annual precipitation
var annualPrecipitation = chirps.select('precipitation').sum().clip(CDMX);
var precipPalette = ['#ffffcc', '#a1dab4', '#41b6c4', '#2c7fb8', '#253494'];
var precipParams = {
  min: 0,
  max: 1500,
  palette: precipPalette
};

// Add the annual precipitation layer to the map
Map.addLayer(annualPrecipitation, precipParams, 'Annual Precipitation (mm)');

// Create pentad (5-day) time series chart
var pentadChart = ui.Chart.image.series({
  imageCollection: processed_chirps.select('precipitation'),
  region: CDMX,
  reducer: ee.Reducer.mean(),
  scale: 5000,
  xProperty: 'system:time_start'
}).setOptions({
  title: 'Pentad (5-day) Precipitation in Mexico City (2024)',
  hAxis: {
    title: 'Date',
    format: 'MMM d',
    gridlines: {count: 12}
  },
  vAxis: {title: 'Precipitation (mm)'},
  lineWidth: 1,
  pointSize: 3,
  series: {0: {color: '#2c7fb8'}}
});

// Print the pentad chart
print("5-day (Pentad) Precipitation Chart", pentadChart);

// Create a cumulative precipitation chart to show accumulation over the year
var cumulativeChart = ui.Chart.image.series({
  imageCollection: processed_chirps.select('precipitation'),
  region: CDMX,
  reducer: ee.Reducer.mean(),
  scale: 5000,
  xProperty: 'system:time_start'
}).setOptions({
  title: 'Cumulative Precipitation in Mexico City (2024)',
  hAxis: {
    title: 'Date',
    format: 'MMM d',
    gridlines: {count: 12}
  },
  vAxis: {title: 'Cumulative Precipitation (mm)'},
  lineWidth: 2,
  curveType: 'function',
  series: {0: {color: '#1d6b99'}},
  trendlines: {0: {
    type: 'polynomial',
    degree: 3,
    color: '#b22400',
    lineWidth: 1,
    opacity: 0.5,
    visibleInLegend: true
  }}
});

// Print the cumulative chart
print("Cumulative Precipitation Chart", cumulativeChart);

// Calculate statistics for each pentad
var pentadStatsList = processed_chirps.map(function(image) {
  var stats = image.select('precipitation').reduceRegion({
    reducer: ee.Reducer.mean().combine({
      reducer2: ee.Reducer.minMax(),
      sharedInputs: true
    }),
    geometry: CDMX,
    scale: 5000,
    maxPixels: 1e9
  });
  
  return ee.Feature(null, {
    'date': image.get('date_string'),
    'pentad': image.get('pentad'),
    'mean': stats.get('precipitation_mean'),
    'min': stats.get('precipitation_min'),
    'max': stats.get('precipitation_max')
  });
});

// Print pentad statistics
print("Pentad Precipitation Statistics", pentadStatsList);

// Create a wet/dry season analysis
// In Mexico City, the wet season is typically May-October
var wetSeasonStart = ee.Date.fromYMD(2024, 5, 1);
var wetSeasonEnd = ee.Date.fromYMD(2024, 10, 31);

var wetSeasonPrecip = chirps
  .filter(ee.Filter.date(wetSeasonStart, wetSeasonEnd))
  .select('precipitation')
  .sum()
  .clip(CDMX);

var drySeasonPrecip = chirps
  .filter(ee.Filter.or(
    ee.Filter.date('2024-01-01', wetSeasonStart),
    ee.Filter.date(wetSeasonEnd, '2024-12-31')
  ))
  .select('precipitation')
  .sum()
  .clip(CDMX);

// Add wet/dry season layers to map
Map.addLayer(wetSeasonPrecip, precipParams, 'Wet Season Precipitation');
Map.addLayer(drySeasonPrecip, {min: 0, max: 300, palette: precipPalette}, 'Dry Season Precipitation', false);

// Calculate seasonal statistics
var wetSeasonStats = wetSeasonPrecip.reduceRegion({
  reducer: ee.Reducer.mean().combine({
    reducer2: ee.Reducer.minMax(),
    sharedInputs: true
  }),
  geometry: CDMX,
  scale: 5000,
  maxPixels: 1e9
});

var drySeasonStats = drySeasonPrecip.reduceRegion({
  reducer: ee.Reducer.mean().combine({
    reducer2: ee.Reducer.minMax(),
    sharedInputs: true
  }),
  geometry: CDMX,
  scale: 5000,
  maxPixels: 1e9
});

// Print seasonal statistics
print("Wet Season (May-Oct) Precipitation Statistics (mm):", wetSeasonStats);
print("Dry Season (Nov-Apr) Precipitation Statistics (mm):", drySeasonStats);

