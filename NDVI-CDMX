// Filter the MODIS images by date
var images = modis.filter(ee.Filter.date(startDate, endDate));
print('Filtered Images:', images);

// Function to scale NDVI values
var scaling = function(image) {
  var scaled = image.select('NDVI').divide(10000);
  return scaled.copyProperties(image, ['system:index', 'system:time_start']);
};

// Map the scaling function over the image collection
var scaled_ndvi = images.map(scaling);
print('Scaled NDVI:', scaled_ndvi);

// Reproject the geometry to match the MODIS projection
var modisProjection = images.first().projection();
var reprojectedCDMX = CDMX.transform(modisProjection, 1);
var reprojectedCU = CU.geometry().transform(modisProjection, 1);

// Clip the first image to the reprojected geometry
var nd = scaled_ndvi.first().clip(reprojectedCDMX);
Map.addLayer(nd, {min: 0, max: 1, palette: ['orange', 'green']}, 'NDVI');

// Create a chart of NDVI over time for both regions
var chart = ui.Chart.image.seriesByRegion({
  imageCollection: scaled_ndvi,
  regions: ee.FeatureCollection([
    ee.Feature(reprojectedCDMX, {label: 'CDMX'}),
    ee.Feature(reprojectedCU, {label: 'CU'})
  ]),
  reducer: ee.Reducer.mean(),
  scale: 250,
  seriesProperty: 'label'
}).setOptions({
  title: 'NDVI Time Series for CDMX and CU',
  hAxis: {title: 'Date'},
  vAxis: {title: 'NDVI'},
  lineWidth: 2,
  pointSize: 3,
  series: {
    0: {color: 'red'},
    1: {color: 'blue'}
  }
});

print(chart);
