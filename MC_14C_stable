%% =====================================================================
%% FIGURA FINAL: Todas las fuentes superpuestas en un solo panel por día
%%               con todos los días de monitoreo en una sola figura
%%               (isotópos estables: δ¹³C + δ¹⁸O + Δ¹⁴C)
%% =====================================================================

n_cols = 4;
n_rows = ceil(n_samples / n_cols);   % = 3 for 12 months

figure('Position', [50, 50, 1600, 900], ...
       'Name', 'Distribuciones combinadas (isótopos estables) – todos los días');

legend_handles = gobjects(3, 1);

for d = 1:n_samples
    ax = subplot(n_rows, n_cols, d);
    hold(ax, 'on');

    max_pdf = 0;

    for k = 1:3
        data = src_data{k}{d};
        if isempty(data)
            continue;
        end

        % Histograma transparente
        histogram(ax, data, 35, ...
                  'Normalization', 'pdf', ...
                  'FaceColor', src_colors{k}, ...
                  'EdgeColor', 'none', ...
                  'FaceAlpha', 0.22);

        % KDE suavizada (clamp para evitar error en bordes)
        data_kde = min(max(data, 0.01), 99.99);
        [f_kde, xi_kde] = ksdensity(data_kde);
        in_range = xi_kde >= 0 & xi_kde <= 100;
        xi_kde = xi_kde(in_range);
        f_kde  = f_kde(in_range);

        ph = plot(ax, xi_kde, f_kde, '-', ...
                  'Color', src_colors{k}, ...
                  'LineWidth', 2.2);

        % Línea vertical en la media
        mn_d = mean(data);
        xline(ax, mn_d, '--', 'Color', src_colors{k}, 'LineWidth', 1.4, 'Alpha', 0.8);

        max_pdf = max(max_pdf, max(f_kde));

        if d == 1
            legend_handles(k) = ph;
        end
    end

    title(ax, day_labels{d}, 'FontSize', 11, 'FontWeight', 'bold');
    xlabel(ax, 'Contribución (%)', 'FontSize', 8.5);
    if mod(d-1, n_cols) == 0
        ylabel(ax, 'Densidad PDF', 'FontSize', 8.5);
    end
    xlim(ax, [0 100]);
    if max_pdf > 0
        ylim(ax, [0, max_pdf * 1.18]);
    end
    grid(ax, 'on');
    box(ax, 'on');
    set(ax, 'FontSize', 8);
    hold(ax, 'off');
end

% Leyenda compartida centrada en la parte inferior
