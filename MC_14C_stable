              'Jun II','Jul','Ago','Ago II','Sep','Oct','Nov','Dic 24'};

n_samples = length(mixed_d13C);

%% Initialize results storage
results = struct();
results.sample_id = (1:n_samples)';
fields = {'fossil','biomass','soil'};
stats  = {'mean','std','median','p5','p95'};
for f = 1:numel(fields)
    for s = 1:numel(stats)
        results.([fields{f} '_' stats{s}]) = zeros(n_samples, 1);
    end
end
results.n_valid      = zeros(n_samples, 1);
results.success_rate = zeros(n_samples, 1);

%% Guardar distribuciones completas
all_fossil_dist  = cell(n_samples, 1);
all_biomass_dist = cell(n_samples, 1);
all_soil_dist    = cell(n_samples, 1);

%% Process each sampling day
fprintf('=== SOURCE APPORTIONMENT: d13C + d18O + 14C ===\n');
fprintf('Procesando %d muestreos con %d iteraciones Monte Carlo\n\n', ...
        n_samples, n_simulations);

for sample_idx = 1:n_samples
    fprintf('--- Muestreo %d/%d (%s) ---\n', sample_idx, n_samples, day_labels{sample_idx});

    f_fossil  = zeros(n_simulations, 1);
    f_biomass = zeros(n_simulations, 1);
    f_soil    = zeros(n_simulations, 1);
    valid_solutions = false(n_simulations, 1);

    for i = 1:n_simulations

        % Muestrear end-members
        s_d13C = normrnd(soil_d13C,    soil_d13C_std);
        s_d18O = normrnd(soil_d18O,    soil_d18O_std);
        s_C14  = normrnd(soil_C14,     soil_C14_std);

        b_d13C = normrnd(biomass_d13C, biomass_d13C_std);
        b_d18O = normrnd(biomass_d18O, biomass_d18O_std);
        b_C14  = normrnd(biomass_C14,  biomass_C14_std);

        ff_d13C = normrnd(fossil_d13C, fossil_d13C_std);
        ff_d18O = normrnd(fossil_d18O, fossil_d18O_std);
        ff_C14  = normrnd(fossil_C14,  fossil_C14_std);

        % Muestrear observaciones
        obs_d13C = normrnd(mixed_d13C(sample_idx), mixed_d13C_std(sample_idx));
        obs_d18O = normrnd(mixed_d18O(sample_idx), mixed_d18O_std(sample_idx));
        obs_14C  = normrnd(obs_C14(sample_idx),    obs_C14_std(sample_idx));

        % Sistema sobredeterminado (4 ecuaciones, 3 incógnitas) → mínimos cuadrados
        A = [1,       1,       1;
             ff_d13C, b_d13C,  s_d13C;
             ff_d18O, b_d18O,  s_d18O;
             ff_C14,  b_C14,   s_C14];

        b_vec = [1; obs_d13C; obs_d18O; obs_14C];

        try
            % Solución por mínimos cuadrados (sistema sobredeterminado)
            fracs = A \ b_vec;

            if all(isreal(fracs)) && all(fracs >= 0) && abs(sum(fracs) - 1) < 0.05

                % Renormalizar para garantizar suma = 1
                total = sum(fracs);
                f_fossil(i)  = fracs(1) / total;
                f_biomass(i) = fracs(2) / total;
                f_soil(i)    = fracs(3) / total;
                valid_solutions(i) = true;
            end
        catch
            continue;
        end
    end

    % Extraer soluciones válidas en %
    f_fossil_valid  = f_fossil(valid_solutions)  * 100;
    f_biomass_valid = f_biomass(valid_solutions) * 100;
    f_soil_valid    = f_soil(valid_solutions)    * 100;
    n_valid = sum(valid_solutions);

    % Guardar distribuciones
    all_fossil_dist{sample_idx}  = f_fossil_valid;
    all_biomass_dist{sample_idx} = f_biomass_valid;
    all_soil_dist{sample_idx}    = f_soil_valid;

    results.n_valid(sample_idx)      = n_valid;
    results.success_rate(sample_idx) = 100 * n_valid / n_simulations;

    if n_valid > 100
        for k = 1:3
            switch k
                case 1; dat = f_fossil_valid;  fld = 'fossil';
                case 2; dat = f_biomass_valid; fld = 'biomass';
                case 3; dat = f_soil_valid;    fld = 'soil';
            end
            results.([fld '_mean'])(sample_idx)   = mean(dat);
            results.([fld '_std'])(sample_idx)    = std(dat);
            results.([fld '_median'])(sample_idx) = median(dat);
            results.([fld '_p5'])(sample_idx)     = prctile(dat, 5);
            results.([fld '_p95'])(sample_idx)    = prctile(dat, 95);
        end
        fprintf('Válidas: %d (%.1f%%) | Fósil: %.1f±%.1f%% | Biomasa: %.1f±%.1f%% | Suelos: %.1f±%.1f%%\n\n', ...
                n_valid, results.success_rate(sample_idx), ...
                results.fossil_mean(sample_idx),  results.fossil_std(sample_idx), ...
                results.biomass_mean(sample_idx), results.biomass_std(sample_idx), ...
                results.soil_mean(sample_idx),    results.soil_std(sample_idx));
    else
        fprintf('ADVERTENCIA: Soluciones insuficientes (%d)\n\n', n_valid);
    end
end

%% =====================================================================
%% FIGURA: Histogramas Monte Carlo por día de monitoreo
%% =====================================================================

src_data   = {all_fossil_dist,  all_biomass_dist,  all_soil_dist};
src_names  = {'Combustión fósil','Quema de biomasa','Respiración de suelos'};
src_colors = {[0.45 0.45 0.45], [0.75 0.25 0.25], [0.25 0.65 0.25]};

for d = 1:n_samples
    figure('Position', [100, 100, 1300, 380], ...
           'Name', sprintf('MC Distribuciones - %s', day_labels{d}));

    for k = 1:3
        subplot(1, 3, k);
        data = src_data{k}{d};

        if isempty(data)
            text(0.5, 0.5, 'Sin datos', 'HorizontalAlignment','center');
            axis off; continue;
        end

        mn  = mean(data);
        p5  = prctile(data, 5);
        p95 = prctile(data, 95);

        histogram(data, 40, 'Normalization', 'pdf', ...
                  'FaceColor', src_colors{k}, 'EdgeColor', 'none', 'FaceAlpha', 0.85);
        hold on;

        xline(mn,  '--', 'Color', src_colors{k}*0.55, 'LineWidth', 2.0);
        xline(p5,  ':',  'Color', src_colors{k}*0.55, 'LineWidth', 1.5);
        xline(p95, ':',  'Color', src_colors{k}*0.55, 'LineWidth', 1.5);

        ylims = ylim;
        ytop  = ylims(2) * 0.97;

        text(mn,  ytop, sprintf(' Media\n %.1f%%', mn), ...
             'FontSize', 7.5, 'Color', src_colors{k}*0.45, ...
             'VerticalAlignment','top','HorizontalAlignment','left');
        text(p5,  ytop, sprintf('IC 95%%\n %.1f%%', p5), ...
             'FontSize', 7.5, 'Color', src_colors{k}*0.45, ...
             'VerticalAlignment','top','HorizontalAlignment','right');
        text(p95, ytop, sprintf('IC 95%%\n %.1f%%', p95), ...
             'FontSize', 7.5, 'Color', src_colors{k}*0.45, ...
             'VerticalAlignment','top','HorizontalAlignment','left');

        title(src_names{k}, 'FontSize', 11, 'FontWeight', 'bold');
        xlabel('Contribución (%)', 'FontSize', 10);
        ylabel('Densidad de probabilidad', 'FontSize', 10);
        xlim([0, 100]);
        grid on; box on;
        hold off;
    end

    sgtitle(sprintf('Monitoreo: %s  |  δ¹³C + δ¹⁸O + Δ¹⁴C', day_labels{d}), ...
            'FontSize', 12, 'FontWeight', 'bold');
end

