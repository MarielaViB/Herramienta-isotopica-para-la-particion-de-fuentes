  '#FFFF00',  // 40-50 Watch
  '#ADFF2F',  // 50-60 No drought
  '#008000',  // 60-70 Good
  '#006400'   // 70+   Excellent
];

var visParams = {min: 0, max: 100, palette: droughtPalette};

