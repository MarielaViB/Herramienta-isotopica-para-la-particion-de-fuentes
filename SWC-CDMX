var cdmx = ee.FeatureCollection([ee.Feature(CDMX)]);

Map.centerObject(CDMX, 11);
Map.addLayer(CDMX, {color: 'white'}, 'CDMX boundary', false);

// ── 2. DATE RANGE ────────────────────────────────────────────
var startDate = '2023-11-01';
var endDate   = '2026-02-01';

// ── 3. LOAD & PROCESS MODIS NDVI (MOD13A2) ───────────────────
var ndviCol = ee.ImageCollection('MODIS/061/MOD13A2')
  .filterDate(startDate, endDate)
  .filterBounds(cdmx)
  .select('NDVI');

// Scale factor: MODIS NDVI is stored ×10000
var scaleNDVI = function(img) {
  return img.multiply(0.0001)
            .copyProperties(img, ['system:time_start']);
};
ndviCol = ndviCol.map(scaleNDVI);

// Long-term min/max for NDVI (entire collection period) per pixel
var ndviMin = ndviCol.min().clip(CDMX);
var ndviMax = ndviCol.max().clip(CDMX);

// VCI per image
var computeVCI = function(img) {
  var vci = img.subtract(ndviMin)
               .divide(ndviMax.subtract(ndviMin))
               .multiply(100)
               .rename('VCI')
               .copyProperties(img, ['system:time_start']);
  return vci;
};
var vciCol = ndviCol.map(computeVCI);

// ── 4. LOAD & PROCESS MODIS LST (MOD11A2) ────────────────────
var lstCol = ee.ImageCollection('MODIS/061/MOD11A2')
  .filterDate(startDate, endDate)
  .filterBounds(cdmx)
  .select('LST_Day_1km');

// Scale factor: LST is stored in Kelvin × 0.02 → convert to °C
var scaleLST = function(img) {
  return img.multiply(0.02).subtract(273.15)
            .copyProperties(img, ['system:time_start']);
};
lstCol = lstCol.map(scaleLST);

// Long-term min/max for LST per pixel
var lstMin = lstCol.min().clip(CDMX);
var lstMax = lstCol.max().clip(CDMX);

// TCI per image  (inverted: higher temp → worse conditions)
var computeTCI = function(img) {
  var tci = lstMax.subtract(img)
                  .divide(lstMax.subtract(lstMin))
                  .multiply(100)
                  .rename('TCI')
                  .copyProperties(img, ['system:time_start']);
  return tci;
};
var tciCol = lstCol.map(computeTCI);

// ── 5. COMBINE VCI + TCI → VHI ───────────────────────────────
// VHI = 0.5 × VCI + 0.5 × TCI  (equal weights, Kogan 1995)
// We join the two collections by date (within ±8 days)
var maxDiff = ee.Filter.maxDifference({
  difference: 8 * 24 * 60 * 60 * 1000,   // 8 days in ms
  leftField:  'system:time_start',
  rightField: 'system:time_start'
});

var joined = ee.Join.saveFirst('tci_match').apply({
  primary:   vciCol,
  secondary: tciCol,
  condition: maxDiff
});

var computeVHI = function(feat) {
  var vci = ee.Image(feat);
  var tci = ee.Image(feat.get('tci_match'));
  var vhi = vci.multiply(0.5).add(tci.multiply(0.5))
               .rename('VHI')
               .copyProperties(vci, ['system:time_start']);
  return vhi;
};
var vhiCol = ee.ImageCollection(joined.map(computeVHI));

// ── 6. VISUALIZATION PALETTES ────────────────────────────────
